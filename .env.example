# Redis
REDIS_URL=redis://redis:6379/0

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_TASK_QUEUE=aiops-alerts

# Feishu 应用机器人（开放平台 -> 应用 -> 凭证与基础信息）
# 同一对凭据用于 ① IM v1 发卡片  ② 长连接接收审批回调
# 长连接模式无需公网域名 / HTTPS / 验签，开发者本机即可跑通
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 默认接收对象（群聊用 chat_id；私聊用 open_id / user_id / email / union_id）
FEISHU_RECEIVE_ID=oc_xxxxxxxxxxxxxxxxxxxxxx
FEISHU_RECEIVE_ID_TYPE=chat_id

# Zabbix webhook inbound auth
ZABBIX_WEBHOOK_TOKEN=change-me

# Audit
AUDIT_LOG_PATH=/app/audit.log

# Ansible
ANSIBLE_PRIVATE_DATA_DIR=/app/ansible
ANSIBLE_INVENTORY=/app/ansible/inventory.ini

# LLM - Primary (OpenAI/DeepSeek/Claude)
LLM_PRIMARY_PROVIDER=openai
LLM_PRIMARY_BASE_URL=https://api.openai.com/v1
LLM_PRIMARY_API_KEY=sk-your-key-here
LLM_PRIMARY_MODEL=gpt-4o

# LLM - Fallback (本地 llama.cpp)
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_BASE_URL=http://localhost:8080/v1
LLM_FALLBACK_API_KEY=not-needed
LLM_FALLBACK_MODEL=local-model

# LLM - General
LLM_TIMEOUT=30
LLM_CIRCUIT_BREAKER_THRESHOLD=0.3

# ========== Phase 3: Policy 层 ==========

# AIOps 执行模式
# live:   按 policy 决策自动执行（默认）
# shadow: 所有 ALLOW 决策只记录不真自动执行（调试新规则用）
AIOPS_MODE=live

# 主机分级（逗号分隔的 IP）
# VM3 (192.168.198.130) 是测试机，留空使其归 dev；不在两者中的主机也默认归 dev
PRODUCTION_HOSTS=
STAGING_HOSTS=

# Policy 配置文件路径（容器内绝对路径）
POLICY_CONFIG_PATH=/app/src/policy/policies.yaml

# ========== Phase 3: 元监控（独立通道） ==========
# 必须用一个独立的飞书自定义机器人！跟 AIOps 主审批群（FEISHU_RECEIVE_ID）分开。
# 在飞书独立运维告警群里点「添加机器人 → 自定义机器人」，复制 webhook URL 填这里。
# 这个机器人专门接收 AIOps 自身故障告警，绝不能跟 AIOps 主流程共用。
META_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-meta-token

# 元监控探测目标；Docker Compose 内可留空 META_TEMPORAL_ADDR，程序会使用默认 Temporal 服务地址。
META_AIOPS_URL=http://aiops:8000
META_TEMPORAL_ADDR=
META_REDIS_ADDR=redis:6379
META_INTERVAL_SEC=60

# ========== Phase 4: 多 Agent 协同 ==========
ALERT_RATE_LIMIT_PER_MIN=100
MAX_PENDING_WORKFLOWS=50
CORRELATOR_WINDOW_SEC=30

# ========== Phase 7: Hermes 知识层 ==========
HERMES_DB_URL=postgresql://temporal:temporal@postgres:5432/temporal
